{
  "version": 2,
  "functions": {
    "api/assets/[id]/download.js": {
      "includeFiles": "souls/**/*.md"
    }
  },
  "routes": [
    {
      "src": "/$",
      "dest": "/api/home.js"
    },
    {
      "src": "/robots\\.txt",
      "dest": "/api/robots.txt.js"
    },
    {
      "src": "/sitemap\\.xml",
      "dest": "/api/sitemap.xml.js"
    },
    {
      "src": "/mcp",
      "dest": "/api/mcp/index.js"
    },
    {
      "src": "/api/mcp",
      "dest": "/api/mcp/index.js"
    },
    {
      "src": "/api/mcp/manifest",
      "dest": "/api/mcp/manifest.js"
    },
    {
      "src": "/api/assets/([^/]+)/download",
      "dest": "/api/assets/[id]/download.js?id=$1"
    },
    {
      "src": "/\\.well-known/api-catalog",
      "dest": "/api/well-known/api-catalog.js"
    },
    {
      "src": "/\\.well-known/mcp/server-card\\.json",
      "dest": "/api/well-known/mcp/server-card.js"
    },
    {
      "src": "/\\.well-known/agent-skills/index\\.json",
      "dest": "/api/well-known/agent-skills/index.js"
    },
    {
      "src": "/\\.well-known/agent-skills/([^/]+)/SKILL\\.md",
      "dest": "/api/well-known/agent-skills/skill.js?name=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/WEBMCP\\.md",
      "dest": "/api/mcp/webmcp_markdown.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
