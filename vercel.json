{
  "version": 2,
  "functions": {
    "api/mcp/manifest.js": {
      "includeFiles": "public/index.html"
    },
    "api/asset-page.js": {
      "includeFiles": "public/asset.html"
    },
    "api/assets/[id]/download.js": {
      "includeFiles": "souls/**/*.md"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/api/mcp/manifest.js?view=home",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/mcp",
      "dest": "/api/mcp/index.js"
    },
    {
      "src": "/api/mcp",
      "dest": "/api/mcp/index.js"
    },
    {
      "src": "/api/mcp/manifest",
      "dest": "/api/mcp/manifest.js"
    },
    {
      "src": "/api/assets/([^/]+)/download",
      "dest": "/api/assets/[id]/download.js?id=$1"
    },
    {
      "src": "/assets/([^/]+)",
      "dest": "/api/asset-page.js?id=$1"
    },
    {
      "src": "/asset\\.html",
      "dest": "/api/asset-page.js"
    },
    {
      "src": "/sitemap\\.xml",
      "dest": "/api/sitemap.xml.js"
    },
    {
      "src": "/\\.well-known/api-catalog",
      "dest": "/api/well-known/api-catalog.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/WEBMCP\\.md",
      "dest": "/api/mcp/webmcp_markdown.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
